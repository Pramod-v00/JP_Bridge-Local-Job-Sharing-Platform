# MongoDB
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/kaampay

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# NOTE: No OTP service needed — authentication uses phone + password only.

# Cloudinary (Images & Audio)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin
ADMIN_SECRET_KEY=admin_secret_to_create_admin_account

# Server
PORT=5000
CLIENT_URL=http://localhost:3000
